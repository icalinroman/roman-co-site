---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="rentnbuy | Roman & Co">
  <Header />

  <main class="bg-[#efefef] pb-20 pt-10 md:pb-28 md:pt-14">
    <section class="mx-auto max-w-[1880px] px-4 md:px-6">
      <div class="pt-10 md:pt-14">
        <div class="border-y border-dotted border-black/35">
          <div class="grid gap-0 xl:grid-cols-[1.7fr_0.5fr_0.7fr_0.5fr]">
            <div class="px-0 py-6 md:py-8 xl:pr-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#3a3a44]">
                Case Study 03
              </p>

              <h1 class="mt-6 text-[46px] font-medium tracking-[-0.04em] text-[#2f2f37] md:text-[64px]">
                rentnbuy
              </h1>
            </div>

            <div class="border-l border-dotted border-black/35 px-6 py-6 md:px-8 md:py-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                Client
              </p>

              <p class="font-mono-custom mt-6 text-[24px] leading-[1.2] text-[#3a3a44] md:text-[28px]">
                Proptech
                <br />
                Real Estate
                <br />
                Platform
              </p>
            </div>

            <div class="border-l border-dotted border-black/35 px-6 py-6 md:px-8 md:py-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                Services
              </p>

              <p class="font-mono-custom mt-6 text-[24px] leading-[1.2] text-[#3a3a44] md:text-[28px]">
                Brand Strategy,
                <br />
                Ads & Performance,
                <br />
                Multi-channel campaigns
              </p>
            </div>

            <div class="border-l border-dotted border-black/35 px-6 py-6 md:px-8 md:py-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                Year
              </p>

              <p class="font-mono-custom mt-6 text-[24px] leading-[1.2] text-[#3a3a44] md:text-[28px]">
                2025-2026
              </p>
            </div>
          </div>
        </div>

        <div class="mt-10 overflow-hidden rounded-[24px] bg-[#cfd8e3]">
          <div class="flex h-[340px] w-full items-center justify-center bg-[#cfd8e3] text-[28px] text-[#3a3a44] md:h-[520px] xl:h-[760px]">
            rentnbuy Hero Video
          </div>
        </div>

        <div class="mt-10 grid gap-10 xl:grid-cols-[0.95fr_0.9fr] xl:gap-12">
          <div>
            <div class="font-mono-custom text-[24px] leading-[1.35] text-[#3a3a44] md:text-[28px]">
              <section>
                <p class="mb-5 font-sans text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                  Challenge
                </p>

                <p class="max-w-[760px]">
                  Rentnbuy entered a highly competitive real estate market dominated by legacy platforms, high commissions, and low transparency.
                </p>

                <p class="mt-4 max-w-[760px]">
                  The challenge was to position a new, AI-powered, zero-commission rental platform in a market where trust, pricing sensitivity, and habit-driven behavior strongly influence consumer decisions.
                </p>
              </section>

              <section class="mt-14">
                <p class="mb-5 font-sans text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                  Our Solution
                </p>

                <div class="max-w-[760px] space-y-4">
                  <p>
                    We built a growth and positioning strategy focused on clarity, differentiation, and behavioral insight.
                  </p>

                  <p>This included:</p>

                  <p>
                    • Defining the zero-commission positioning and core narrative
                  </p>

                  <p>
                    • Developing the brand strategy and communication framework
                  </p>

                  <p>
                    • Designing and executing digital acquisition campaigns
                  </p>

                  <p>
                    • Aligning product, marketing, and executive communication under one cohesive growth direction
                  </p>
                </div>
              </section>

              <section class="mt-14">
                <p class="mb-5 font-sans text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                  The Result
                </p>

                <div class="max-w-[760px] space-y-4">
                  <p>
                    • 150,000+ monthly platform visits
                  </p>

                  <p>
                    • Hundreds of property listings across Romania’s largest cities
                  </p>

                  <p>
                    • Strong early brand recognition in a highly competitive category
                  </p>

                  <p>
                    • Media presence across major TV and media outlets such as Forbes, ZF, ProTV, Wall-Street and many more.
                  </p>
                </div>
              </section>
            </div>

            <div class="mt-16 grid max-w-[560px] grid-cols-2 gap-8 md:gap-12">
              <div>
                <div class="text-[58px] font-medium leading-none tracking-[-0.05em] text-[#2f2f37] md:text-[82px]">
                  10K
                </div>
                <p class="mt-3 max-w-[220px] text-[24px] font-medium leading-[1.08] tracking-[-0.03em] text-[#3a3a44]">
                  Users in First Months
                </p>
              </div>

              <div>
                <div class="text-[58px] font-medium leading-none tracking-[-0.05em] text-[#2f2f37] md:text-[82px]">
                  +2M
                </div>
                <p class="mt-3 max-w-[220px] text-[24px] font-medium leading-[1.08] tracking-[-0.03em] text-[#3a3a44]">
                  Impact on Target Audience
                </p>
              </div>
            </div>

            <div class="mt-12 grid max-w-[620px] grid-cols-2 gap-4 md:gap-5">
              <div class="overflow-hidden rounded-[22px] bg-[#d7dde5]">
                <div class="flex h-[240px] w-full items-center justify-center bg-[#d7dde5] text-[22px] text-[#3a3a44] md:h-[430px]">
                  rentnbuy Small Image 01
                </div>
              </div>

              <div class="overflow-hidden rounded-[22px] bg-[#d7dde5]">
                <div class="flex h-[240px] w-full items-center justify-center bg-[#d7dde5] text-[22px] text-[#3a3a44] md:h-[430px]">
                  rentnbuy Small Image 02
                </div>
              </div>
            </div>
          </div>

          <div class="overflow-hidden rounded-[24px] bg-[#d8e5ef]">
            <div class="flex h-full min-h-[420px] w-full items-center justify-center bg-[#d8e5ef] text-[28px] text-[#3a3a44] xl:min-h-[1500px]">
              rentnbuy Side Image
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mt-16 md:mt-20">
      <Footer />
    </div>
  </main>
</BaseLayout>