---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
---

<BaseLayout title="Caresyntax | Roman & Co">
  <Header />
  <main class="bg-[#efefef] px-6 py-24">
    <div class="mx-auto max-w-[1200px]">
      <h1 class="text-[56px] font-medium uppercase tracking-[-0.05em] text-[#2f2f37]">
        Pepe Rosso
      </h1>
      <p class="font-mono-custom mt-6 text-[24px] text-[#3a3a44]">
        Project page in progress.
      </p>
    </div>
  </main>
</BaseLayout>