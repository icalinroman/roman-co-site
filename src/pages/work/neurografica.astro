---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Neurografica | Roman & Co">
  <Header />

  <main class="bg-[#efefef] pt-10 md:pt-14">
    <section class="mx-auto max-w-[1880px] px-4 md:px-6">
      <div class="pt-8 md:pt-10">
        <div class="border-y border-dotted border-black/35">
          <div class="grid gap-0 xl:grid-cols-[1.7fr_0.55fr_0.65fr_0.45fr]">
            <div class="px-0 py-6 md:py-8 xl:pr-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#3a3a44]">
                Case Study 04
              </p>

              <h1 class="mt-6 text-[46px] font-medium tracking-[-0.04em] text-[#2f2f37] md:text-[64px]">
                Neurografica
              </h1>
            </div>

            <div class="border-l border-dotted border-black/35 px-6 py-6 md:px-8 md:py-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                Client
              </p>

              <p class="font-mono-custom mt-6 text-[24px] leading-[1.2] text-[#3a3a44] md:text-[28px]">
                Online Personal
                <br />
                Development
                <br />
                Program
              </p>
            </div>

            <div class="border-l border-dotted border-black/35 px-6 py-6 md:px-8 md:py-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                Services
              </p>

              <p class="font-mono-custom mt-6 text-[24px] leading-[1.2] text-[#3a3a44] md:text-[28px]">
                Ads & Performance,
                <br />
                Funnel Creation,
                <br />
                Strategy
              </p>
            </div>

            <div class="border-l border-dotted border-black/35 px-6 py-6 md:px-8 md:py-8">
              <p class="text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                Year
              </p>

              <p class="font-mono-custom mt-6 text-[24px] leading-[1.2] text-[#3a3a44] md:text-[28px]">
                2024-2026
              </p>
            </div>
          </div>
        </div>

        <div class="mt-10 grid gap-4 md:gap-6 xl:grid-cols-[0.48fr_1fr]">
          <div class="overflow-hidden rounded-[24px] bg-[#c9d3de]">
            <div class="flex h-[340px] w-full items-center justify-center bg-[#c9d3de] text-[26px] text-[#3a3a44] md:h-[520px] xl:h-[760px]">
              Hero Image Left
            </div>
          </div>

          <div class="relative overflow-hidden rounded-[24px] bg-[#cdb7d6]">
            <div class="absolute left-6 top-6 z-10 text-[38px] font-medium leading-none tracking-[-0.05em] text-white md:left-8 md:top-8 md:text-[68px] xl:text-[92px]">
              Neurografica
            </div>

            <div class="flex h-[340px] w-full items-center justify-center bg-[#cdb7d6] text-[26px] text-white/90 md:h-[520px] xl:h-[760px]">
              Hero Image Right
            </div>
          </div>
        </div>

        <div class="mt-12 grid gap-10 xl:grid-cols-[0.92fr_0.88fr] xl:gap-14">
          <div>
            <div class="font-mono-custom text-[24px] leading-[1.35] text-[#3a3a44] md:text-[28px]">
              <section>
                <p class="max-w-[780px]">
                  Neurografica operated in a niche, education-based space where the concept was unfamiliar to most audiences and required explanation before conversion.
                </p>

                <p class="mt-4 max-w-[780px]">
                  The challenge was to structure a clear positioning, build trust in a highly emotional category, and create a predictable lead generation system for workshops and programs.
                </p>
              </section>

              <section class="mt-14">
                <p class="mb-5 font-sans text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                  Our Solution
                </p>

                <div class="max-w-[780px] space-y-4">
                  <p>
                    We developed a full funnel strategy focused on behavioral triggers and clarity of message.
                  </p>

                  <p>This included:</p>

                  <p>
                    • Defining positioning and simplifying the value proposition
                  </p>

                  <p>
                    • Building a structured acquisition funnel from cold traffic to workshop enrollment
                  </p>

                  <p>
                    • Designing and executing paid campaigns focused on education-first messaging
                  </p>

                  <p>
                    • Creating conversion flows aligned with emotional decision-making patterns
                  </p>
                </div>
              </section>

              <section class="mt-14">
                <p class="mb-5 font-sans text-[18px] font-medium uppercase tracking-[0.01em] text-[#7b7b7b]">
                  The Result
                </p>

                <div class="max-w-[780px] space-y-4">
                  <p>
                    • Crossed $1M in revenue
                  </p>

                  <p>
                    • Predictable lead generation pipeline
                  </p>

                  <p>
                    • Increased workshop enrollment through structured funnel optimization
                  </p>

                  <p>
                    • Clearer brand positioning in a previously abstract category
                  </p>
                </div>
              </section>
            </div>

            <div class="mt-16 grid max-w-[560px] grid-cols-2 gap-8 md:gap-12">
              <div>
                <div class="text-[58px] font-medium leading-none tracking-[-0.05em] text-[#2f2f37] md:text-[82px]">
                  $1M+
                </div>
                <p class="mt-3 max-w-[220px] text-[24px] font-medium leading-[1.08] tracking-[-0.03em] text-[#3a3a44]">
                  Sales From Funnel
                </p>
              </div>

              <div>
                <div class="text-[58px] font-medium leading-none tracking-[-0.05em] text-[#2f2f37] md:text-[82px]">
                  30k+
                </div>
                <p class="mt-3 max-w-[220px] text-[24px] font-medium leading-[1.08] tracking-[-0.03em] text-[#3a3a44]">
                  Generated Leads at Competitive CPLs
                </p>
              </div>
            </div>
          </div>

          <div>
            <div class="grid grid-cols-2 gap-4 md:gap-6">
              <div class="overflow-hidden rounded-[22px] bg-[#ddd4ea]">
                <div class="flex h-[220px] w-full items-center justify-center bg-[#ddd4ea] text-[22px] text-[#3a3a44] md:h-[320px]">
                  Small Image 01
                </div>
              </div>

              <div class="overflow-hidden rounded-[22px] bg-[#d7d9e8]">
                <div class="flex h-[220px] w-full items-center justify-center bg-[#d7d9e8] text-[22px] text-[#3a3a44] md:h-[320px]">
                  Small Image 02
                </div>
              </div>

              <div class="overflow-hidden rounded-[22px] bg-[#cfbfdc]">
                <div class="flex h-[220px] w-full items-center justify-center bg-[#cfbfdc] text-[22px] text-[#3a3a44] md:h-[320px]">
                  Small Image 03
                </div>
              </div>

              <div class="overflow-hidden rounded-[22px] bg-[#d6d1e0]">
                <div class="flex h-[220px] w-full items-center justify-center bg-[#d6d1e0] text-[22px] text-[#3a3a44] md:h-[320px]">
                  Small Image 04
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-14 grid gap-4 md:gap-6 xl:grid-cols-2">
          <div class="overflow-hidden rounded-[24px] bg-[#c8c1da]">
            <div class="flex h-[320px] w-full items-center justify-center bg-[#c8c1da] text-[26px] text-[#3a3a44] md:h-[520px] xl:h-[680px]">
              Large Bottom Image 01
            </div>
          </div>

          <div class="overflow-hidden rounded-[24px] bg-[#d8d4e2]">
            <div class="flex h-[320px] w-full items-center justify-center bg-[#d8d4e2] text-[26px] text-[#3a3a44] md:h-[520px] xl:h-[680px]">
              Large Bottom Image 02
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mt-16 md:mt-20">
      <Footer />
    </div>
  </main>
</BaseLayout>