---
import '../styles/global.css';
const { title = 'Roman & Co' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Roman & Co builds strategic marketing systems for growth-focused brands."
    />
  </head>
  <body class="bg-[#efefef] text-[#26262f] antialiased">
    <slot />
  </body>
</html>