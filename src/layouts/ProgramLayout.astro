---
import '../styles/global.css';
const { title = 'Program' } = Astro.props;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Transformă expertiza ta într-un software validat. Program practic pentru antreprenori, consultanți și specialiști non-tehnici."
    />
  </head>
  <body class="program-page antialiased">
    <slot />
  </body>
</html>