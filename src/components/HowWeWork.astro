---
const steps = [
  {
    number: '01',
    title: 'Research & behavioural strategy',
    text:
      'We start with context. We analyze consumer psychology, market dynamics, and real-world data to define positioning, messaging, and strategic direction grounded in how people actually make decisions.',
  },
  {
    number: '02',
    title: 'Multi-channel execution',
    text:
      'Strategy means nothing without execution. We translate positioning into coordinated action across paid media, organic content, PR, email, and partnerships, ensuring consistency across every touchpoint.',
  },
  {
    number: '03',
    title: 'Tracking & performance intelligence',
    text:
      'We measure what matters. Beyond surface-level metrics, we track behavioral signals, conversion paths, retention patterns, and brand perception indicators to understand true impact.',
  },
  {
    number: '04',
    title: 'Adaptation & scaling',
    text:
      'Markets shift. Audiences evolve. We continuously refine campaigns, test new angles, and scale what works, building sustainable growth instead of short-term spikes.',
  },
];
---

<section class="relative bg-[#efefef] py-20 md:py-24" id="about">
  <div class="mx-auto max-w-[1240px] px-6">
    <div class="mb-12 max-w-[760px]">
      <p class="mb-4 text-[13px] font-medium uppercase tracking-[0.35em] text-[#3a3a44]/50">
        How we work with brands
      </p>

      <h2 class="text-[38px] font-bold uppercase leading-[0.95] tracking-[-0.04em] text-[#2c2c35] md:text-[58px]">
        Strategy built for real market behaviour
      </h2>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {steps.map((step) => (
        <article class="rounded-[28px] border border-black/8 bg-[#f6f4f4]/90 p-7 shadow-[0_10px_35px_rgba(0,0,0,0.04)] md:p-8">
          <div class="mb-5 flex items-center justify-between">
            <span class="text-[13px] font-medium uppercase tracking-[0.28em] text-[#2f2f37]/45">
              {step.number}
            </span>

            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[#e8b0f0] text-[15px] font-semibold text-[#2d2431]">
              +
            </span>
          </div>

          <h3 class="max-w-[420px] text-[28px] font-bold uppercase leading-[1] tracking-[-0.03em] text-[#2b2b33]">
            {step.title}
          </h3>

          <p class="mt-6 text-[16px] leading-[1.75] text-[#3a3a44]/80">
            {step.text}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>