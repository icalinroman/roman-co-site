<section id="contact" class="bg-[#efefef] pb-20 md:pb-28">
  <div class="mx-auto max-w-[1880px] px-4 md:px-6">
    <div class="rounded-[22px] bg-[#e3a6e8] px-6 py-8 md:px-10 md:py-10 xl:px-12 xl:py-12">
      <div class="grid gap-10 xl:grid-cols-[0.95fr_1.05fr] xl:gap-14">
        
        <div class="flex items-start">
          <h2 class="max-w-[620px] text-[54px] font-medium uppercase leading-[0.92] tracking-[-0.05em] text-[#2f2f37] md:text-[82px] xl:text-[92px]">
            Let’s craft your brand strategy
          </h2>
        </div>

        <div class="relative">
          <div class="absolute right-0 top-0 hidden md:block">
            <div class="flex h-12 w-12 items-center justify-center text-[#2f2f37]">
              <svg
                viewBox="0 0 64 64"
                class="h-11 w-11"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <rect x="16" y="12" width="32" height="40" rx="2" stroke="currentColor" stroke-width="2.5"/>
                <path d="M22 20H42" stroke="currentColor" stroke-width="2.5"/>
                <path d="M22 26H42" stroke="currentColor" stroke-width="2.5"/>
                <rect x="24" y="31" width="16" height="12" rx="1.5" stroke="currentColor" stroke-width="2.5"/>
                <path d="M29 37L31 39L35 35" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 18V54" stroke="currentColor" stroke-width="2.5"/>
                <path d="M52 18V54" stroke="currentColor" stroke-width="2.5"/>
              </svg>
            </div>
          </div>

          <form class="max-w-[720px] pt-2 md:pt-0">
            <div class="grid gap-6 md:grid-cols-2">
              <div>
                <label for="firstName" class="mb-3 block text-[15px] font-medium uppercase tracking-[0.02em] text-[#2f2f37]">
                  First Name *
                </label>
                <input
                  id="firstName"
                  name="firstName"
                  type="text"
                  class="h-[52px] w-full border-0 border-b border-[#2f2f37]/70 bg-transparent px-0 text-[18px] text-[#2f2f37] outline-none focus:border-[#2f2f37]"
                />
              </div>

              <div>
                <label for="lastName" class="mb-3 block text-[15px] font-medium uppercase tracking-[0.02em] text-[#2f2f37]">
                  Last Name *
                </label>
                <input
                  id="lastName"
                  name="lastName"
                  type="text"
                  class="h-[52px] w-full border-0 border-b border-[#2f2f37]/70 bg-transparent px-0 text-[18px] text-[#2f2f37] outline-none focus:border-[#2f2f37]"
                />
              </div>
            </div>

            <div class="mt-5">
              <label for="email" class="mb-3 block text-[15px] font-medium uppercase tracking-[0.02em] text-[#2f2f37]">
                Email *
              </label>
              <input
                id="email"
                name="email"
                type="email"
                class="h-[52px] w-full border-0 border-b border-[#2f2f37]/70 bg-transparent px-0 text-[18px] text-[#2f2f37] outline-none focus:border-[#2f2f37]"
              />
            </div>

            <div class="mt-5">
              <label for="message" class="mb-3 block text-[15px] font-medium uppercase tracking-[0.02em] text-[#2f2f37]">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="3"
                class="w-full resize-none border-0 border-b border-[#2f2f37]/70 bg-transparent px-0 py-2 text-[18px] text-[#2f2f37] outline-none focus:border-[#2f2f37]"
              ></textarea>
            </div>

            <div class="mt-6">
              <button
                type="submit"
                class="inline-flex h-[46px] min-w-[166px] items-center justify-center rounded-full border border-[#2f2f37] px-8 text-[20px] font-normal text-[#2f2f37] transition hover:bg-[#2f2f37] hover:text-white"
              >
                Submit
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>