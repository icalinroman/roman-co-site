---
const studies = [
  {
    name: 'Neurografica',
    value1: '$1M+',
    label1: 'Sales From Funnel',
    value2: '30k+',
    label2: 'Generated Leads At\nCompetitive CPLs',
    tags: ['Paid Ads', 'Performance', 'Strategy'],
    image: '/neurografica-case.png',
    alt: 'Neurografica case study',
  },
  {
    name: 'Caresyntax',
    value1: '+12M',
    label1: 'Impact On Target Audience',
    value2: '35+',
    label2: 'Global Conferences',
    tags: ['PR', 'Executive Branding', 'Performance'],
    image: '/caresyntax-case.jpg',
    alt: 'Caresyntax case study',
  },
  {
    name: 'rentnbuy',
    value1: '10k+',
    label1: 'Users In First Months',
    value2: '+2M',
    label2: 'Impact On Target Audience',
    tags: ['Brand Strategy', 'Ads', 'Growth'],
    image: '/rentnbuy-case.jpg',
    alt: 'rentnbuy case study',
  },
];
---

<section id="work" class="bg-[#efefef] py-20 md:py-28">
  <div class="mx-auto max-w-[1320px] px-6">
    <div class="grid items-start gap-14 xl:grid-cols-[0.78fr_1.22fr]">
      <div class="xl:sticky xl:top-28">
        <h2 class="reveal max-w-[620px] text-[48px] font-bold uppercase leading-[0.95] tracking-[-0.045em] text-[#2c2c35] md:text-[72px]">
          From local brands to c-series global start-ups
        </h2>

        <p class="font-mono-custom reveal reveal-delay-1 mt-10 max-w-[620px] text-[20px] leading-[1.45] text-[#3a3a44] md:text-[21px]">
          We’ve worked with brands of all sizes — from early-stage tech startups to established eCommerce and retail companies. Across industries and growth stages, our focus remains the same: building clear positioning, aligning strategy with real consumer behavior, and executing across channels in a way that drives sustainable growth.
        </p>

        <div class="reveal reveal-delay-2 mt-10">
          <a
            href="#contact"
            class="inline-flex h-[54px] items-center rounded-full bg-[#e9a8ef] px-10 text-[16px] font-semibold uppercase tracking-[0.02em] text-[#2d2431] transition hover:scale-[1.02] hover:opacity-95"
          >
            See Our Work +
          </a>
        </div>
      </div>

      <div class="space-y-8 [perspective:1400px]">
        {studies.map((study, index) => (
          <article
            class={`reveal-flip group overflow-hidden rounded-[26px] border border-black/8 bg-[#f4f1f1] shadow-[0_14px_40px_rgba(0,0,0,0.05)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_22px_50px_rgba(0,0,0,0.08)] ${
              index === 1 ? 'reveal-flip-delay-1' : ''
            } ${
              index === 2 ? 'reveal-flip-delay-2' : ''
            }`}
          >
            <div class="grid xl:grid-cols-[0.95fr_0.8fr]">
              <div class="p-6 md:p-8">
                <div class="font-mono-custom text-[20px] text-[#35353d] md:text-[24px]">
                  {study.name}
                </div>

                <div class="mt-8 grid grid-cols-2 gap-0 border-t border-dashed border-black/25">
                  <div class="min-w-0 border-r border-dashed border-black/25 pr-5 pt-6">
                    <div class="text-[54px] font-bold leading-none tracking-[-0.05em] text-[#2d2d35] md:text-[76px]">
                      {study.value1}
                    </div>
                    <div class="mt-4 max-w-[190px] text-[18px] font-medium leading-[1.08] text-[#373740] md:text-[20px]">
                      {study.label1}
                    </div>
                  </div>

                  <div class="min-w-0 pl-5 pt-6">
                    <div class="text-[54px] font-bold leading-none tracking-[-0.05em] text-[#2d2d35] md:text-[76px]">
                      {study.value2}
                    </div>
                    <div class="mt-4 max-w-[210px] whitespace-pre-line text-[18px] font-medium leading-[1.08] text-[#373740] md:text-[20px]">
                      {study.label2}
                    </div>
                  </div>
                </div>

                <div class="mt-8 flex flex-wrap gap-3">
                  {study.tags.map((tag) => (
                    <span class="font-mono-custom inline-flex h-[42px] items-center rounded-[14px] border border-black/25 px-5 text-[16px] text-[#3a3a44]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <div class="relative min-h-[300px] bg-[#c8dcee]">
                <img
                  src={study.image}
                  alt={study.alt}
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                />
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
