---
const pathname = Astro.url.pathname;

const isWorkPage =
  pathname === '/work' || pathname.startsWith('/work/');

const isCaresyntax = pathname === '/work/caresyntax';
const isWaterbear = pathname === '/work/waterbear';
const isRentnbuy = pathname === '/work/rentnbuy';
const isNeurografica = pathname === '/work/neurografica';
const isPepeRosso = pathname === '/work/pepe-rosso';

const navLinkClass = (active: boolean) =>
  `text-[15px] uppercase transition hover:opacity-70 ${
    active ? 'font-semibold text-[#2b2b33]' : 'font-medium text-[#2b2b33]/65'
  }`;

const dropdownLinkClass = (active: boolean) =>
  `block text-[15px] transition hover:opacity-60 ${
    active ? 'font-semibold text-[#2b2b33]' : 'font-normal text-[#2b2b33]'
  }`;
---

<header class="absolute left-0 top-0 z-50 w-full">
  <div class="mx-auto flex max-w-[1180px] justify-center px-6 pt-7">
    <div class="flex h-[58px] w-full max-w-[620px] items-center justify-between rounded-full bg-[#f5f2f2] px-6 shadow-[0_8px_30px_rgba(0,0,0,0.05)]">
      <a href="/" class="text-[12px] font-semibold uppercase tracking-[0.18em] text-[#274690]">
        Roman&Co.
      </a>

      <nav class="flex items-center gap-8">
        <div class="group relative">
          <a
            href="/work"
            class={`flex items-center gap-1 ${navLinkClass(isWorkPage)}`}
          >
            Work
            <span class="text-[12px]">⌄</span>
          </a>

          <div class="pointer-events-none absolute left-0 top-full pt-2 opacity-0 transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100">
            <div class="min-w-[190px] rounded-[18px] bg-[#f5f2f2] p-4 shadow-[0_10px_30px_rgba(0,0,0,0.08)]">
              <div class="space-y-2">
                <a href="/work/caresyntax" class={dropdownLinkClass(isCaresyntax)}>
                  Caresyntax
                </a>
                <a href="/work/waterbear" class={dropdownLinkClass(isWaterbear)}>
                  Waterbear
                </a>
                <a href="/work/rentnbuy" class={dropdownLinkClass(isRentnbuy)}>
                  rentnbuy
                </a>
                <a href="/work/neurografica" class={dropdownLinkClass(isNeurografica)}>
                  Neurografica
                </a>
                <a href="/work/pepe-rosso" class={dropdownLinkClass(isPepeRosso)}>
                  Pepe Rosso
                </a>
              </div>
            </div>
          </div>
        </div>

        <a href="/about" class={navLinkClass(pathname === '/about')}>
        About
        </a>

        <a href="/#contact" class={navLinkClass(false)}>
          Contact
        </a>
      </nav>
    </div>
  </div>
</header>